{
  "name": "@proxima-io/templateizer",
  "version": "0.2.2",
  "type": "module",
  "description": "CLI for managing Proxima website templates — scan, validate, register, deploy, publish, sync, and status.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "proxima-templateizer": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "publish:pkg": "pnpm publish --no-git-checks"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@proxima-io/template-registry-client": "workspace:*",
    "@proxima-io/template-schema": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
