---
import { buildEditableAttributeProps, type CmsEditorKind } from "./inspect-meta.ts";

interface Props {
  enabled?: boolean;
  name?: string | null;
  attributeKey?: string | null;
  type?: string | null;
  label?: string | null;
  ui?: string | null;
  localizable?: boolean;
  editorKind?: CmsEditorKind | string | null;
  as?: "div" | "span" | "p" | "h1" | "h2" | "h3" | "h4" | "section" | "article" | "a";
  class?: string;
  style?: string;
  href?: string;
}

const {
  enabled = false,
  name = null,
  attributeKey = null,
  type = null,
  label = null,
  ui = null,
  localizable = false,
  editorKind = null,
  as = "div",
  class: className = "",
  style,
  href,
} = Astro.props;

const Tag = as;
const fieldName = name ?? attributeKey ?? "field";
const resolved = buildEditableAttributeProps(
  { label, type, attribute_key: attributeKey, localizable },
  fieldName,
  {
    label: label ?? undefined,
    type: type ?? undefined,
    ui: ui ?? undefined,
    localizable,
    attributeKey: attributeKey ?? undefined,
  },
);

const key = attributeKey || resolved.attributeKey || fieldName;
const kind = editorKind || resolved.editorKind;
const inspectTitle = resolved.inspectTitle;
const kindLabel = resolved.editorKindLabel;
---

{enabled && key ? (
  <Tag
    class={className}
    style={style}
    href={href}
    data-cms-attribute={key}
    data-cms-attribute-key={key}
    data-cms-attribute-type={resolved.type || undefined}
    data-cms-attribute-label={inspectTitle || undefined}
    data-cms-inspect-title={inspectTitle || undefined}
    data-cms-inspect-kind="attribute"
    data-cms-editor-kind={kind || undefined}
    data-cms-editor-kind-label={kindLabel || undefined}
    data-cms-attribute-ui={resolved.ui || undefined}
    data-cms-localizable={localizable ? "true" : undefined}
  >
    <slot />
  </Tag>
) : (
  <Tag class={className} style={style} href={href}>
    <slot />
  </Tag>
)}
