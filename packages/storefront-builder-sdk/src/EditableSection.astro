---
import { buildSectionInspectTitle } from "./inspect-meta.ts";

interface Props {
  enabled?: boolean;
  pageId?: number | string | null;
  sectionId?: number | string | null;
  sectionType?: string | null;
  sectionName?: string | null;
  as?: "section" | "div" | "article" | "aside" | "header" | "footer" | "main";
  class?: string;
}

const {
  enabled = false,
  pageId = null,
  sectionId = null,
  sectionType = null,
  sectionName = null,
  as = "section",
  class: className = "",
} = Astro.props;

const Tag = as;
const inspectTitle = buildSectionInspectTitle(sectionName, sectionType);
---

{enabled && sectionId ? (
  <Tag
    class={className}
    data-cms-editable="true"
    data-cms-page-id={pageId != null ? String(pageId) : undefined}
    data-cms-section-id={String(sectionId)}
    data-cms-section-type={sectionType || undefined}
    data-cms-section-name={sectionName || undefined}
    data-cms-label={inspectTitle || undefined}
    data-cms-inspect-title={inspectTitle || undefined}
    data-cms-inspect-kind="section"
    data-cms-editor-kind="section"
    data-cms-editor-kind-label="Sección"
  >
    <slot />
  </Tag>
) : (
  <slot />
)}
