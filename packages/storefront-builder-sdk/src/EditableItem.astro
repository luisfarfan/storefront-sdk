---
import { buildEditableItemInspectTitle } from "./inspect-meta.ts";

interface Props {
  enabled?: boolean;
  itemType?: string | null;
  itemIndex?: number | string | null;
  itemKey?: string | null;
  itemLabel?: string | null;
  parentAttributeKey?: string | null;
  as?: "div" | "li" | "article" | "span" | "a";
  class?: string;
  href?: string;
}

const {
  enabled = false,
  itemType = null,
  itemIndex = null,
  itemKey = null,
  itemLabel = null,
  parentAttributeKey = null,
  as = "div",
  class: className = "",
  href,
  ...rest
} = Astro.props;

const Tag = as;
const inspectTitle = buildEditableItemInspectTitle({
  itemLabel,
  itemType,
  itemIndex,
  parentAttributeKey,
});
---

{enabled ? (
  <Tag
    class={className}
    href={href}
    {...rest}
    data-cms-item="true"
    data-cms-item-type={itemType || undefined}
    data-cms-item-index={itemIndex != null ? String(itemIndex) : undefined}
    data-cms-item-key={itemKey || undefined}
    data-cms-item-label={itemLabel || itemType || undefined}
    data-cms-inspect-title={inspectTitle || undefined}
    data-cms-inspect-kind="item"
    data-cms-editor-kind="item"
    data-cms-editor-kind-label="Ítem"
    data-cms-item-parent-key={parentAttributeKey || undefined}
  >
    <slot />
  </Tag>
) : (
  <Tag class={className} href={href} {...rest}>
    <slot />
  </Tag>
)}
