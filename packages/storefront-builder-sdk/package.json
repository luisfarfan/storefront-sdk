{
  "name": "@proxima-io/storefront-builder-sdk",
  "version": "0.3.0",
  "type": "module",
  "description": "Proxima Builder iframe bridge and editable component wrappers for Astro storefronts.",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./BuilderEmptyState.astro": "./src/BuilderEmptyState.astro",
    "./CmsPreviewBridge.astro": "./src/CmsPreviewBridge.astro",
    "./EditableSection.astro": "./src/EditableSection.astro",
    "./EditableAttribute.astro": "./src/EditableAttribute.astro",
    "./EditableItem.astro": "./src/EditableItem.astro",
    "./preview.css": "./src/preview.css",
    "./inspect-meta": "./src/inspect-meta.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "echo 'nothing to clean'",
    "publish:pkg": "pnpm publish --no-git-checks"
  },
  "peerDependencies": {
    "astro": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
