# URL base de la API de Proxima
PROXIMA_API_URL=https://api.proxima.io

# Dominio del storefront (debe coincidir con el Website en el admin)
PROXIMA_DOMAIN=mitienda.proxima.app

# Service key del tenant (se obtiene en el admin de Proxima)
PROXIMA_SERVICE_KEY=sk_live_...

# Business ID del tenant (se obtiene en el admin de Proxima)
PROXIMA_BUSINESS_ID=1

# Igual que PROXIMA_API_URL pero expuesto al browser (para analytics y search)
PUBLIC_PROXIMA_API_URL=https://api.proxima.io
