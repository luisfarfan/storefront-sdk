{
  "_comment": "Este archivo es para publicar el storefront como template en el Proxima Marketplace (templateizer register/publish). Para deployar a un website específico de un cliente, usa proxima.website.json + templateizer website-deploy.",

  "template_key": "storefront-starter",
  "name": "Storefront Starter",
  "slug": "storefront-starter",
  "description": "Punto de partida para un storefront Proxima con Astro. Incluye header, hero, grilla de productos, categorías, búsqueda y footer.",
  "category": "ecommerce",
  "industry": "retail",
  "tags": ["astro", "ecommerce", "starter"],

  "deployment_config": {
    "runtime_kind": "external",
    "preview_url": "",
    "production_url": ""
  },

  "repository_config": {},
  "renderer_contract": {},
  "capabilities": ["cart", "search", "wishlist", "buyer_auth"],
  "theme_tokens": {},
  "animation_config": {},

  "section_types": [
    {
      "key": "header",
      "label": "Header",
      "category": "navigation",
      "renderer": "HeaderSection",
      "attribute_schema": [
        { "name": "logo",      "label": "Logo",               "type": "image", "order": 1 },
        { "name": "nav_links", "label": "Links de navegación", "type": "array", "order": 2,
          "config": {
            "item_fields": [
              { "name": "label", "type": "text" },
              { "name": "url",   "type": "text" }
            ]
          }
        }
      ]
    },
    {
      "key": "hero",
      "label": "Hero Principal",
      "category": "content",
      "renderer": "HeroSection",
      "attribute_schema": [
        { "name": "image",       "label": "Imagen de fondo", "type": "image", "is_required": true, "order": 1 },
        { "name": "headline",    "label": "Título",          "type": "text",  "localizable": true,  "order": 2 },
        { "name": "subheadline", "label": "Subtítulo",       "type": "text",  "localizable": true,  "order": 3 },
        { "name": "cta",         "label": "Botón CTA",       "type": "link",                        "order": 4 }
      ]
    },
    {
      "key": "product_grid",
      "label": "Grilla de Productos",
      "category": "commerce",
      "renderer": "ProductGridSection",
      "attribute_schema": [
        { "name": "headline", "label": "Título",    "type": "text",                "localizable": true, "order": 1 },
        { "name": "products", "label": "Productos", "type": "smart_collection_id", "order": 2,
          "config": { "allowed_smart_collection_types": ["product_list", "manual"] }
        },
        { "name": "columns",  "label": "Columnas",  "type": "number",              "order": 3,
          "config": { "min": 2, "max": 5 }
        }
      ]
    },
    {
      "key": "category_grid",
      "label": "Grilla de Categorías",
      "category": "commerce",
      "renderer": "CategoryGridSection",
      "attribute_schema": [
        { "name": "headline",   "label": "Título",     "type": "text",                "localizable": true, "order": 1 },
        { "name": "categories", "label": "Categorías", "type": "smart_collection_id", "order": 2,
          "config": { "allowed_smart_collection_types": ["category_list"] }
        }
      ]
    },
    {
      "key": "search",
      "label": "Búsqueda",
      "category": "commerce",
      "renderer": "SearchSection",
      "attribute_schema": [
        { "name": "placeholder", "label": "Placeholder del buscador", "type": "text", "localizable": true, "order": 1 }
      ]
    },
    {
      "key": "footer",
      "label": "Footer",
      "category": "navigation",
      "renderer": "FooterSection",
      "attribute_schema": [
        { "name": "copyright", "label": "Texto de copyright", "type": "text",  "order": 1 },
        { "name": "links",     "label": "Links del footer",   "type": "array", "order": 2,
          "config": {
            "item_fields": [
              { "name": "label", "type": "text" },
              { "name": "url",   "type": "text" }
            ]
          }
        }
      ]
    }
  ],

  "pages": [
    {
      "name": "Home",
      "path": "/",
      "resolver_kind": "content_page",
      "order": 1,
      "sections": [
        { "name": "Header",         "type": "header",       "order": 1  },
        { "name": "Hero",           "type": "hero",         "order": 2  },
        { "name": "Destacados",     "type": "product_grid", "order": 3  },
        { "name": "Categorías",     "type": "category_grid","order": 4  },
        { "name": "Footer",         "type": "footer",       "order": 99 }
      ]
    },
    {
      "name": "Detalle de Producto",
      "path": "/producto/{slug}",
      "resolver_kind": "product_detail",
      "order": 2,
      "sections": [
        { "name": "Header", "type": "header", "order": 1  },
        { "name": "Footer", "type": "footer", "order": 99 }
      ]
    },
    {
      "name": "Categoría",
      "path": "/categoria/{slug}",
      "resolver_kind": "category_detail",
      "order": 3,
      "sections": [
        { "name": "Header",    "type": "header",       "order": 1  },
        { "name": "Productos", "type": "product_grid", "order": 2  },
        { "name": "Footer",    "type": "footer",       "order": 99 }
      ]
    },
    {
      "name": "Búsqueda",
      "path": "/buscar",
      "resolver_kind": "search",
      "order": 4,
      "sections": [
        { "name": "Header",   "type": "header", "order": 1  },
        { "name": "Búsqueda", "type": "search", "order": 2  },
        { "name": "Footer",   "type": "footer", "order": 99 }
      ]
    }
  ],

  "smart_collection_placeholders": []
}
