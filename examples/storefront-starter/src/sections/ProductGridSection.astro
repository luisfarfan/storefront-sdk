---
import { EditableSection, EditableAttribute } from '@proxima-io/storefront-builder-sdk';
import type { CmsSection } from '@proxima-io/storefront-cms';
import ProductCard from '../components/ProductCard.astro';
import type { StorefrontProductSummary } from '@proxima-io/storefront-core';

interface SmartCollectionResult {
  type: string;
  items: StorefrontProductSummary[];
  meta: { limit: number; returned: number; total?: number; truncated?: boolean; count: number };
}

interface Props {
  section: CmsSection;
}

const { section } = Astro.props;
const {
  headline = '',
  products,
  columns = 4,
} = section.attributes as {
  headline?: string;
  products?: SmartCollectionResult;
  columns?: number;
};

const items = products?.items ?? [];
const hasProducts = items.length > 0;
---

<EditableSection {section}>
  <section class="product-grid-section">
    <div class="product-grid-section__inner">
      {headline && (
        <EditableAttribute {section} attributeKey="headline">
          <h2 class="product-grid-section__title">{headline}</h2>
        </EditableAttribute>
      )}

      {hasProducts ? (
        <>
          <div
            class="product-grid-section__grid"
            style={`--cols: ${columns}`}
            id="products-grid"
          >
            {items.map(product => (
              <ProductCard {product} />
            ))}
          </div>

          {products?.meta?.truncated && (
            <div class="product-grid-section__footer">
              <button
                id="load-more-btn"
                class="product-grid-section__load-more"
                data-page="2"
                data-total={products.meta.total}
                data-returned={products.meta.returned}
              >
                Ver más productos
                {products.meta.total && (
                  <span>({products.meta.total - products.meta.returned} restantes)</span>
                )}
              </button>
            </div>
          )}
        </>
      ) : (
        <p class="product-grid-section__empty">
          Productos próximamente.
        </p>
      )}
    </div>
  </section>
</EditableSection>

<script>
  import { fetchStorefrontProducts } from '@proxima-io/storefront-core';

  const btn = document.getElementById('load-more-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const page = parseInt((btn as HTMLButtonElement).dataset.page ?? '2');
      (btn as HTMLButtonElement).textContent = 'Cargando...';
      (btn as HTMLButtonElement).disabled = true;

      try {
        const listing = await fetchStorefrontProducts(
          { baseUrl: import.meta.env.PUBLIC_PROXIMA_API_URL },
          {
            business_id: window.__PROXIMA_BUSINESS_ID__,
            locale: document.documentElement.lang,
            currency: window.__PROXIMA_CURRENCY__,
          },
          { page }
        );

        const grid = document.getElementById('products-grid');
        if (grid) {
          listing.items.forEach(product => {
            const card = document.createElement('div');
            card.innerHTML = `
              <article class="product-card">
                <a href="/producto/${product.slug}">
                  <img src="${product.image_url}" alt="${product.name}" loading="lazy" />
                  <h3>${product.name}</h3>
                  <p>${product.price_formatted ?? product.price}</p>
                </a>
              </article>
            `;
            grid.appendChild(card.firstElementChild!);
          });
        }

        if (listing.pagination.page < listing.pagination.total_pages) {
          (btn as HTMLButtonElement).dataset.page = String(page + 1);
          (btn as HTMLButtonElement).disabled = false;
          (btn as HTMLButtonElement).textContent = 'Ver más productos';
        } else {
          btn.remove();
        }
      } catch {
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = 'Ver más productos';
      }
    });
  }
</script>

<style>
  .product-grid-section { padding: 4rem 0; }
  .product-grid-section__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .product-grid-section__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #111827;
    margin: 0 0 2rem;
  }
  .product-grid-section__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 1024px) {
    .product-grid-section__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .product-grid-section__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .product-grid-section__grid { grid-template-columns: 1fr; }
  }
  .product-grid-section__footer {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }
  .product-grid-section__load-more {
    padding: 0.75rem 2.5rem;
    background: transparent;
    border: 2px solid #111827;
    color: #111827;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: var(--proxima-radius, 8px);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .product-grid-section__load-more:hover {
    background: #111827;
    color: white;
  }
  .product-grid-section__load-more:disabled { opacity: 0.5; cursor: wait; }
  .product-grid-section__empty {
    text-align: center;
    color: #9ca3af;
    padding: 3rem 0;
  }
</style>
