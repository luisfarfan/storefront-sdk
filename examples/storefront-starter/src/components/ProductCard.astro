---
import type { StorefrontProductSummary } from '@proxima-io/storefront-core';

interface Props {
  product: StorefrontProductSummary;
}

const { product } = Astro.props;
---

<article class="product-card">
  <a href={`/producto/${product.slug}`} class="product-card__link">
    <div class="product-card__image-wrap">
      {product.image_url
        ? <img src={product.image_url} alt={product.name} loading="lazy" />
        : <div class="product-card__image-placeholder" />
      }
      {product.badge && (
        <span class="product-card__badge">{product.badge}</span>
      )}
    </div>
    <div class="product-card__info">
      {product.brand_name && (
        <p class="product-card__brand">{product.brand_name}</p>
      )}
      <h3 class="product-card__name">{product.name}</h3>
      <p class="product-card__price">
        {product.price_formatted ?? product.price}
      </p>
    </div>
  </a>

  <div class="product-card__actions">
    <button
      class="product-card__add-to-cart"
      data-variant-id={product.default_variant_id}
    >
      Agregar al carrito
    </button>
    <button
      class="product-card__wishlist wishlist-btn"
      data-product-id={product.id}
      aria-label="Agregar a favoritos"
    >
      ♡
    </button>
  </div>
</article>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: var(--proxima-radius, 12px);
    overflow: hidden;
    border: 1px solid #e5e7eb;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .product-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  .product-card__link { text-decoration: none; color: inherit; }
  .product-card__image-wrap {
    position: relative;
    aspect-ratio: 1;
    background: #f9fafb;
    overflow: hidden;
  }
  .product-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .product-card:hover .product-card__image-wrap img { transform: scale(1.05); }
  .product-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: #f3f4f6;
  }
  .product-card__badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: var(--proxima-primary, #111);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .product-card__info { padding: 0.875rem 1rem 0.5rem; }
  .product-card__brand {
    font-size: 0.75rem;
    color: #9ca3af;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .product-card__name {
    font-size: 0.9375rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
    color: #111827;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .product-card__price {
    font-size: 1rem;
    font-weight: 700;
    color: var(--proxima-primary, #111);
    margin: 0;
  }
  .product-card__actions {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1rem 1rem;
    margin-top: auto;
  }
  .product-card__add-to-cart {
    flex: 1;
    padding: 0.625rem;
    background: var(--proxima-primary, #111);
    color: white;
    border: none;
    border-radius: var(--proxima-radius, 8px);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .product-card__add-to-cart:hover { opacity: 0.85; }
  .product-card__wishlist {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    border: none;
    border-radius: var(--proxima-radius, 8px);
    cursor: pointer;
    font-size: 1.125rem;
    transition: background 0.15s, color 0.15s;
  }
  .product-card__wishlist:hover,
  .product-card__wishlist.is-active { background: #fee2e2; color: #ef4444; }
</style>
