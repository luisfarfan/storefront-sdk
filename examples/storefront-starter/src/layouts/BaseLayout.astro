---
import { CmsPreviewBridge } from '@proxima-io/storefront-builder-sdk';
import { isCmsPreview } from '@proxima-io/storefront-cms';
import type { ProximaWebsiteResponse } from '@proxima-io/storefront-core';
import CartDrawer from '../components/CartDrawer.astro';

interface Props {
  website: ProximaWebsiteResponse;
  seo?: {
    meta_title?: string;
    meta_description?: string;
    og_image_url?: string;
    robots?: string;
  };
}

const { website, seo } = Astro.props;
const isPreview = isCmsPreview(Astro.url);

function buildCssVars(tokens: Record<string, string> | undefined): string {
  if (!tokens) return '';
  return Object.entries(tokens)
    .map(([k, v]) => `--proxima-${k}: ${v}`)
    .join('; ');
}

const themeVars = buildCssVars(website.theme_tokens as Record<string, string>);
---

<!doctype html>
<html lang={website.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo?.meta_title ?? website.name}</title>
    {seo?.meta_description && (
      <meta name="description" content={seo.meta_description} />
    )}
    {seo?.og_image_url && (
      <meta property="og:image" content={seo.og_image_url} />
    )}
    <meta name="robots" content={seo?.robots ?? 'index, follow'} />
    {themeVars && <style set:html={`:root { ${themeVars} }`} />}
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body { margin: 0; font-family: system-ui, sans-serif; }
      img { max-width: 100%; height: auto; }
    </style>

    <!--
      Datos del website para scripts client-side.
      Usamos data-attributes en lugar de window globals para evitar
      contaminación del scope global y seguir el patrón idiomático de Astro.
    -->
    <meta
      id="proxima-config"
      data-website-id={website.id}
      data-business-id={website.business_id}
      data-locale={website.locale}
      data-currency={(website as any).currency ?? 'USD'}
    />
  </head>
  <body>
    <!-- Builder bridge: solo activo en preview mode, noop en producción -->
    <CmsPreviewBridge enabled={isPreview} />

    <slot />

    <!-- Carrito lateral -->
    <CartDrawer />

    <!--
      Inicialización client-side: analytics + globals de carrito.

      Este script es type="module" (Astro lo bundlea automáticamente),
      por lo que es DIFERIDO — nunca bloquea el parsing del HTML ni el
      primer render, sin impacto en SEO ni en LCP.

      Los datos del website se leen desde #proxima-config (definido en <head>)
      para evitar un script inline síncrono con define:vars.

      apiUrl usa import.meta.env.PUBLIC_PROXIMA_API_URL directamente —
      Astro reemplaza las variables PUBLIC_* en build time en scripts de módulo,
      sin necesidad de pasarlas por window.
    -->
    <script>
      import { analytics } from '@proxima-io/storefront-core';

      const cfg = document.getElementById('proxima-config')!;
      const { websiteId, businessId, locale, currency } = cfg.dataset;

      // Globals para componentes client-side que los necesiten (ej. CartDrawer)
      (window as any).__PROXIMA_BUSINESS_ID__ = businessId;
      (window as any).__PROXIMA_CURRENCY__    = currency;

      analytics.init({
        apiUrl:     import.meta.env.PUBLIC_PROXIMA_API_URL,
        websiteId:  websiteId!,
        businessId: businessId!,
        locale,
      });
    </script>
  </body>
</html>
